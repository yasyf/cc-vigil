# SwiftFormat (nicklockwood) — mechanical formatting only; SwiftLint owns the
# judgment rules. NOT Apple's swift-format: the binary is `swiftformat`
# (brew install swiftformat) and this config file is `.swiftformat`.
# --swiftversion is the language mode, not the tools version.
--swiftversion 6.0
--indent 4
--exclude build,CCVigilShared/.build,Generated
# CI's swiftformat enables these by default; pin them on so local lint agrees.
--enable redundantSendable
--enable preferCountWhere
